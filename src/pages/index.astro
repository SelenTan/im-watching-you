---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../config";
---

<BaseLayout sideBarActiveItemID="home">
    <div class="pb-12 mt-5">
        <img src={url('favicon.svg')} alt="" class="w-24 h-24 mb-2" />
        <div class="text-xl py-1">
            Hey! You are under my watch! Beware of what you do here!
        </div>
        <div class="text-5xl font-bold">I'm Selene</div>

        <div class="mt-10 space-y-3">
            <div class="text-2xl font-bold">Notice Board</div>
            <div class="text-lg">
                This place is mostly harmless, lightly supervised, and full of
                things I am still figuring out.
            </div>
            <div class="text-lg">
                Projects are where I try to make ideas behave. Blog posts are
                where I let them misbehave first.
            </div>
            <div class="text-lg">
                Notes are for course thoughts, tiny discoveries, and future me
                who will absolutely forget everything otherwise.
            </div>
            <div class="text-lg">
                Try clicking WhatsApp. There's a surprise.
            </div>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-[220px_1fr] md:items-center">
            <div class="rounded-ac-lg border border-base-300 bg-base-200/60 p-3">
                <img
                    src={url("tj11.jpg")}
                    alt="Sweet Daisy the ginger cat"
                    class="aspect-square w-full rounded-ac-lg object-cover"
                />
            </div>
            <div class="space-y-3">
                <div class="text-2xl font-bold">Meet my cat</div>
                <div class="text-lg">
                    His name is a mystery that no one fully agrees on.
                </div>
                <div class="text-lg">
                    Want to know the true story? It is hiding under
                    <a
                        href={url("blog/")}
                        class="font-bold underline decoration-dotted underline-offset-4"
                    >
                        blog
                    </a>.
                </div>
            </div>
        </div>

        <div class="mt-12 space-y-3">
            <div class="text-2xl font-bold">A Brief Introduction</div>
            <div class="text-xl">
                I study machine learning systems at UCL, collect good questions,
                and turn messy ideas into little working things. <br />
                This is my corner for projects, notes, and whatever I am curious
                enough to chase next.
            </div>
        </div>
    </div>
</BaseLayout>
