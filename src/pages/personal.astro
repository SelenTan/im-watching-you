---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { AUTHOR_INITIAL, url } from "src/config";
---

<BaseLayout
    title={AUTHOR_INITIAL + " | Personal"}
    sideBarActiveItemID="personal"
>
    <div class="w-[10rem] mt-5 mb-6">
        <Image
            class="fill-current rounded-ac-md"
            format="webp"
            width={300}
            height={300}
            src={url('favicon.svg')}
            alt="icon"
        />
    </div>
    <div class="mb-5">
        <div class="text-3xl w-full font-bold">About Me</div>
    </div>

    <div class="mb-10 text-justify">
        Hi, I'm Selene. I am currently studying MSc Integrated Machine Learning
        Systems at UCL, which means I spend a lot of time thinking about how
        models behave once they leave neat notebooks and meet real constraints.
        I like building things that are both technically sharp and a little bit
        personal: tools, notes, projects, and small experiments that make ideas
        easier to test, explain, or enjoy.
    </div>
</BaseLayout>
