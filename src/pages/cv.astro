---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { AUTHOR_INITIAL } from "src/config";
---

<BaseLayout title={AUTHOR_INITIAL + " | Resume"} sideBarActiveItemID="cv">
    <div class="mb-5">
        <div class="text-3xl w-full font-bold">Education</div>
    </div>

    <div class="time-line-container grid gap-4 mb-10">
        <TimeLineElement
            title="MSc Integrated Machine Learning Systems"
            subtitle="University College London (UCL), London | Sep. 2025 - Jun. 2026"
        >
            Main courses include Applied Machine Learning Systems, Machine
            Learning System Design, Deep Learning for Natural Language
            Processing, Security and Privacy, and Advanced Embedded Design for
            IoT Systems.
        </TimeLineElement>

        <TimeLineElement
            title="BEng Electronic and Electrical Engineering"
            subtitle="Queen Mary University of London, London | Sep. 2022 - Jun. 2025"
        >
            First Class Honours. Coursework included Digital System Design, C
            Programming, Microcontrollers, Digital Signal Processing, and
            Communications and Networking Technologies.
        </TimeLineElement>
    </div>

    <div class="mb-5">
        <div class="text-3xl w-full font-bold">A Few Projects I Did</div>
    </div>

    <div class="time-line-container grid gap-4 mb-10">
        <TimeLineElement
            title="AI-Based Trading Decision System for S&P 500"
            subtitle="UCL Individual Project | Oct. 2025 - Jan. 2026"
        >
            Built a reproducible Python and SQLite pipeline for financial
            time-series data, benchmarked Logistic Regression against an LSTM
            policy network in PyTorch, and evaluated buy/hold/sell signals with
            leak-free temporal splitting, causal backtesting, transaction costs,
            confusion matrices, and multi-seed robustness checks.
        </TimeLineElement>

        <TimeLineElement
            title="Breast Tumor Classification using Classical ML and CNN"
            subtitle="UCL Individual Project | Oct. 2025 - Feb. 2026"
        >
            Engineered SVM and CNN pipelines for benign and malignant ultrasound
            image classification, comparing model capacity, augmentation, and
            training budgets with accuracy, precision, recall, and F1-score on
            held-out test data.
        </TimeLineElement>

        <TimeLineElement
            title="Real-Time Game Development on STM32 with FreeRTOS"
            subtitle="UCL Individual Project | Oct. 2025 - Dec. 2025"
        >
            Designed an interactive embedded game using STM32, a dot matrix
            display, and analog joystick input. Structured display, input, and
            game-state logic as coordinated FreeRTOS tasks for responsive
            real-time behaviour.
        </TimeLineElement>

        <TimeLineElement
            title="Indoor Visible Light Positioning System"
            subtitle="QMUL Graduation Project | Sep. 2024 - Jun. 2025"
        >
            Designed an indoor positioning and navigation system using optical
            signals, Arduino control, a rotating photoelectric sensor, and
            trilateration to estimate position and support obstacle-aware
            navigation.
        </TimeLineElement>

        <TimeLineElement
            title="Autonomous Sumo Robot"
            subtitle="QMUL Group Leader | Jan. 2024 - Apr. 2024"
        >
            Led the development of a micro autonomous sumo robot under strict
            size, weight, and budget constraints, combining custom navigation
            algorithms with iterative hardware and software testing.
        </TimeLineElement>
    </div>

    <div class="mb-5">
        <div class="text-3xl w-full font-bold">Skills</div>
    </div>

    <ul class="list-disc mx-6 mb-10 grid gap-2">
        <li>Programming: Python and C.</li>
        <li>Machine learning: classical ML, CNNs, LSTMs, evaluation, and backtesting.</li>
        <li>Embedded systems: STM32, FreeRTOS, HAL drivers, ADC, GPIO, and microcontrollers.</li>
        <li>Engineering tools: MATLAB, Vivado, CST Studio Suite, COMSOL, and office software.</li>
        <li>Languages: English and Mandarin.</li>
    </ul>
</BaseLayout>
